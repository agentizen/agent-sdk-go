{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent SDK model registry source",
  "type": "object",
  "x-source-version": 1,
  "required": [
    "version",
    "providers"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "base_url",
          "docs_url",
          "pricing_url",
          "models"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]*$",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "base_url": {
            "type": "string",
            "minLength": 1
          },
          "docs_url": {
            "type": "string"
          },
          "pricing_url": {
            "type": "string"
          },
          "models": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "display_name",
                "description",
                "release_date",
                "context_window",
                "capabilities",
                "pricing"
              ],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9.-]*$",
                  "minLength": 1
                },
                "display_name": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "release_date": {
                  "type": "string"
                },
                "context_window": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_output_tokens": {
                  "type": "integer",
                  "minimum": 1
                },
                "capabilities": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "audioGeneration": {
                      "type": "boolean"
                    },
                    "batchAPI": {
                      "type": "boolean"
                    },
                    "caching": {
                      "type": "boolean"
                    },
                    "codeExecution": {
                      "type": "boolean"
                    },
                    "documents": {
                      "type": "boolean"
                    },
                    "fileSearch": {
                      "type": "boolean"
                    },
                    "functionCalling": {
                      "type": "boolean"
                    },
                    "imageGeneration": {
                      "type": "boolean"
                    },
                    "liveAPI": {
                      "type": "boolean"
                    },
                    "structuredOutput": {
                      "type": "boolean"
                    },
                    "thinking": {
                      "type": "boolean"
                    },
                    "vision": {
                      "type": "boolean"
                    }
                  }
                },
                "pricing": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "BatchCachedInputCostPerMillion":       { "type": "number", "minimum": 0 },
                    "BatchInputCostPerMillion":             { "type": "number", "minimum": 0 },
                    "BatchOutputCostPerMillion":            { "type": "number", "minimum": 0 },
                    "CachedInputCostPerMillion":            { "type": "number", "minimum": 0 },
                    "EstimatedCostPerMinute":               { "type": "number", "minimum": 0 },
                    "EstimatedCostPerSecond":               { "type": "number", "minimum": 0 },
                    "InputCostPerMillion":                  { "type": "number", "minimum": 0 },
                    "LongContextCachedInputCostPerMillion": { "type": "number", "minimum": 0 },
                    "LongContextInputCostPerMillion":       { "type": "number", "minimum": 0 },
                    "LongContextOutputCostPerMillion":      { "type": "number", "minimum": 0 },
                    "LongContextTriggerAtTokens":           { "type": "integer", "minimum": 0 },
                    "OcrInputCostPerThousandPages":         { "type": "number", "minimum": 0 },
                    "OcrOutputCostPerThousandPages":        { "type": "number", "minimum": 0 },
                    "OutputCostPerMillion":                 { "type": "number", "minimum": 0 },
                    "PriorityCachedInputCostPerMillion":    { "type": "number", "minimum": 0 },
                    "PriorityInputCostPerMillion":          { "type": "number", "minimum": 0 },
                    "PriorityOutputCostPerMillion":         { "type": "number", "minimum": 0 },
                    "TrainingCostPerHour":                  { "type": "number", "minimum": 0 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
